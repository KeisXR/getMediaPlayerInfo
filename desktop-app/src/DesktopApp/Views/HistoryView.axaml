<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DesktopApp.ViewModels"
             xmlns:models="using:DesktopApp.Models"
             x:Class="DesktopApp.Views.HistoryView"
             x:DataType="vm:HistoryViewModel">

  <DockPanel Margin="16">

    <!-- ── Toolbar ──────────────────────────────────────────────────── -->
    <Grid DockPanel.Dock="Top"
          ColumnDefinitions="*,Auto,Auto,Auto,Auto"
          Margin="0,0,0,12">

      <!-- Search box -->
      <TextBox Grid.Column="0"
               Text="{Binding SearchText}"
               Watermark="🔍  Search by title, artist, album…"
               Padding="10,6"
               FontSize="13"
               Margin="0,0,8,0" />

      <Button Grid.Column="1"
              Content="📤 Export CSV"
              Command="{Binding ExportCsvCommand}"
              Padding="12,6"
              FontSize="13"
              Margin="0,0,4,0" />

      <Button Grid.Column="2"
              Content="Export JSON"
              Command="{Binding ExportJsonCommand}"
              Padding="12,6"
              FontSize="13"
              Margin="0,0,4,0" />

      <Button Grid.Column="3"
              Content="🗑 Clear"
              Command="{Binding ClearCommand}"
              Padding="12,6"
              FontSize="13" />
    </Grid>

    <!-- ── History DataGrid ─────────────────────────────────────────── -->
    <DataGrid ItemsSource="{Binding FilteredEntries}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              GridLinesVisibility="Horizontal"
              FontSize="13"
              CanUserResizeColumns="True"
              CanUserSortColumns="True">

      <DataGrid.Columns>

        <DataGridTextColumn Header="Time"
                            Binding="{Binding TimestampDisplay}"
                            Width="155" />

        <DataGridTextColumn Header="Title"
                            Binding="{Binding Title}"
                            Width="*" />

        <DataGridTextColumn Header="Artist"
                            Binding="{Binding Artist}"
                            Width="180" />

        <DataGridTextColumn Header="Album"
                            Binding="{Binding Album}"
                            Width="160" />

        <DataGridTextColumn Header="Source"
                            Binding="{Binding SourceApp}"
                            Width="120" />

        <DataGridTextColumn Header="Duration"
                            Binding="{Binding DurationDisplay}"
                            Width="80" />

        <DataGridTextColumn Header="Connection"
                            Binding="{Binding ConnectionName}"
                            Width="120" />

      </DataGrid.Columns>
    </DataGrid>

  </DockPanel>
</UserControl>
