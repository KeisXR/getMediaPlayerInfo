<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DesktopApp.ViewModels"
             x:Class="DesktopApp.Views.NowPlayingView"
             x:DataType="vm:NowPlayingViewModel">

  <UserControl.Styles>
    <Style Selector="Border.media-card">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="20" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer>
    <Grid RowDefinitions="Auto,*" Margin="16">

      <!-- ── Top section: Thumbnail + Media Info ──────────────────── -->
      <Grid Grid.Row="0"
            ColumnDefinitions="220,*"
            Margin="0,0,0,12">

        <!-- Thumbnail placeholder -->
        <Border Grid.Column="0"
                Width="200" Height="200"
                CornerRadius="10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                VerticalAlignment="Top"
                Margin="0,0,16,0">
          <TextBlock Text="🎵"
                     FontSize="64"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Opacity="0.4" />
        </Border>

        <!-- Media info card -->
        <Border Grid.Column="1"
                Classes="media-card"
                VerticalAlignment="Top">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">

            <!-- Cached badge -->
            <Border Grid.Row="0"
                    Background="#5599FF"
                    CornerRadius="4"
                    Padding="6,2"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,8"
                    IsVisible="{Binding IsCached}">
              <TextBlock Text="💾 CACHED"
                         Foreground="White"
                         FontSize="11"
                         FontWeight="Bold" />
            </Border>

            <!-- Title -->
            <TextBlock Grid.Row="1"
                       Text="{Binding Title}"
                       FontSize="22"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4" />

            <!-- Artist — Album -->
            <TextBlock Grid.Row="2"
                       FontSize="15"
                       Margin="0,0,0,12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       TextWrapping="Wrap">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0} · {1}">
                  <Binding Path="Artist" />
                  <Binding Path="Album" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>

            <!-- Status badge -->
            <Border Grid.Row="3"
                    CornerRadius="4"
                    Padding="8,3"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,12">
              <Border.Background>
                <SolidColorBrush Color="{Binding StatusColor}" />
              </Border.Background>
              <TextBlock Text="{Binding StatusLabel}"
                         Foreground="White"
                         FontSize="12"
                         FontWeight="Bold" />
            </Border>

            <!-- Progress bar -->
            <ProgressBar Grid.Row="4"
                         Value="{Binding Progress}"
                         Minimum="0"
                         Maximum="1"
                         Height="8"
                         CornerRadius="4"
                         Margin="0,0,0,4" />

            <!-- Position / Duration -->
            <Grid Grid.Row="5"
                  ColumnDefinitions="*,Auto"
                  Margin="0,0,0,12">
              <TextBlock Grid.Column="0"
                         Text="{Binding PositionText}"
                         FontSize="12"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <TextBlock Grid.Column="1"
                         Text="{Binding DurationText}"
                         FontSize="12"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </Grid>

            <!-- Source + Copy button -->
            <Grid Grid.Row="6"
                  ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0"
                         FontSize="12"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                <TextBlock.Text>
                  <MultiBinding StringFormat="Source: {0}">
                    <Binding Path="SourceApp" />
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
              <Button Grid.Column="1"
                      Content="{Binding ClipboardButtonText}"
                      Command="{Binding CopyToClipboardCommand}"
                      Padding="10,4"
                      FontSize="12" />
            </Grid>

          </Grid>
        </Border>
      </Grid>

      <!-- ── Bottom section: Connection info ──────────────────────── -->
      <Border Grid.Row="1"
              Classes="media-card"
              Margin="0,0,0,0">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
            <TextBlock Text="Connection"
                       FontWeight="Bold"
                       FontSize="13"
                       Margin="0,0,0,4" />
            <TextBlock Text="{Binding ConnectionStatus}"
                       FontSize="13">
              <TextBlock.Foreground>
                <SolidColorBrush Color="{Binding ConnectionColor}" />
              </TextBlock.Foreground>
            </TextBlock>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2"
                      HorizontalAlignment="Right">
            <TextBlock Text="{Binding ServerInfo}"
                       FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Right" />
          </StackPanel>
        </Grid>
      </Border>

    </Grid>
  </ScrollViewer>
</UserControl>
